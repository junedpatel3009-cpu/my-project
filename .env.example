# Environment variables for production
# Copy this file to .env and fill in the values

# Database connection string
# For SQLite: file:./prisma/app.db (ensure the directory is writable and backed up)
# For PostgreSQL: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="file:./prisma/app.db"

# SMTP settings for email notifications
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="your_smtp_user"
SMTP_PASS="your_smtp_password"
SMTP_FROM="Your Service <noreply@example.com>"

# Secret for signing session cookies and JWTs
# Generate a strong random string (e.g., 32 bytes base64)
AUTH_SECRET="your_strong_random_secret_here"

# Base URL of the application (used in emails and redirects)
APP_URL="https://yourdomain.com"

# Google OAuth (if used)
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# Google Maps API key (for frontend)
VITE_GOOGLE_MAPS_API_KEY="your_google_maps_api_key"
VITE_GOOGLE_MAPS_JS_ENABLED="true"

# Other settings
# NODE_ENV=production (usually set by the hosting platform)
