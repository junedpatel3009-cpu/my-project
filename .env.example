# Database
DATABASE_URL="file:./prisma/app.db"

# Email OTP
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Servio <your-email@gmail.com>"

# Auth
AUTH_SECRET="replace-with-a-long-random-secret"
JWT_SECRET="replace-with-a-long-random-jwt-secret"
APP_URL="http://localhost:5173"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Standalone backend API
BACKEND_PORT=5000
BACKEND_DATABASE_PATH="backend/data/backend.sqlite"

# Realtime socket server
SOCKET_PORT=4001
SOCKET_CLIENT_ORIGIN="http://localhost:5173"
VITE_SOCKET_URL="http://localhost:4001"

# Optional public services
VITE_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"
VITE_GOOGLE_MAPS_JS_ENABLED="true"
