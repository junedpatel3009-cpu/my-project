// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  ADMIN
  CLIENT
  PROFESSIONAL
}

enum JobUrgency {
  LOW
  MEDIUM
  HIGH
}

enum JobWorkMode {
  ON_SITE
  REMOTE
  BOTH
}

enum JobStatus {
  DRAFT
  OPEN
  CLOSED
}

enum CmsPageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model CmsPage {
  id              Int           @id @default(autoincrement())
  title           String
  slug            String        @unique
  content         String        @default("")
  metaTitle       String        @default("")
  metaDescription String        @default("")
  status          CmsPageStatus @default(DRAFT)
  pageKey         String        @default("")
  sections        String        @default("{}")
  keywords        String        @default("")
  ogTitle         String        @default("")
  ogDescription   String        @default("")
  ogImage         String        @default("")
  canonicalUrl    String        @default("")
  createdAt       DateTime
  updatedAt       DateTime

  @@index([slug])
  @@index([status])
  @@map("cms_pages")
}

model CmsPageVersion {
  id        Int      @id @default(autoincrement())
  pageId    Int      @map("page_id")
  versionNo Int      @map("version_no")
  content   String
  createdBy Int?     @map("created_by")
  createdAt DateTime @map("created_at")

  @@unique([pageId, versionNo])
  @@index([pageId])
  @@map("cms_page_versions")
}

model CmsMedia {
  id        Int      @id @default(autoincrement())
  name      String
  mimeType  String
  url       String
  createdBy Int?
  createdAt DateTime

  @@index([createdAt])
  @@map("cms_media")
}

model User {
  id                     Int             @id @default(autoincrement())
  role                   UserRole        @default(CLIENT)
  firstName              String
  lastName               String
  email                  String          @unique
  phone                  String?         @unique
  passwordHash           String?
  googleId               String?         @unique
  avatarUrl              String?
  companyName            String?
  companyWebsite         String?
  industry               String?
  teamSize               String?
  companyDescription     String?
  address                String?
  professionalCategory   String?
  professionalCity       String?
  professionalSkillsJson String?
  experienceYears        Int?
  hourlyRate             Int?
  fixedRate              Int?
  portfolioUrl           String?
  workPhotosJson         String?
  certificationsJson     String?
  tradeLicenseUrl        String?
  serviceArea            String?
  workMode               String          @default("both")
  serviceRadiusKm        Int?
  averageRating          Float           @default(0)
  reviewCount            Int             @default(0)
  isVerified             Boolean         @default(false)
  availabilityStatus     String          @default("available")
  savedLocationsJson     String?
  hiringNeedsJson        String?
  authProvider           String          @default("LOCAL")
  isActive               Boolean         @default(true)
  lastLoginAt            DateTime?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  clientProfiles         ClientProfile[]
  clientJobs             ClientJob[]
  favoriteJobs           FavoriteJob[]
}

model ClientProfile {
  id                 Int                   @id @default(autoincrement())
  userId             Int
  fullName           String
  email              String
  phone              String
  companyName        String
  companyWebsite     String?
  industry           String?
  teamSize           String?
  companyDescription String?
  address            String
  profilePhotoUrl    String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedLocations     ClientSavedLocation[]
  hiringNeeds        ClientHiringNeed[]

  @@index([userId])
}

model ClientSavedLocation {
  id              Int           @id @default(autoincrement())
  clientProfileId Int
  label           String
  address         String
  createdAt       DateTime      @default(now())
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  @@index([clientProfileId])
}

model ClientHiringNeed {
  id              Int           @id @default(autoincrement())
  clientProfileId Int
  value           String
  createdAt       DateTime      @default(now())
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  @@index([clientProfileId])
}

model ClientJob {
  id              Int                   @id @default(autoincrement())
  userId          Int
  category        String
  title           String
  description     String
  budgetMin       Int?
  budgetMax       Int?
  urgency         JobUrgency            @default(MEDIUM)
  jobDate         DateTime?
  deadline        DateTime
  workMode        JobWorkMode           @default(BOTH)
  locationLabel   String?
  locationAddress String?
  locationLat     Float?
  locationLng     Float?
  status          JobStatus             @default(OPEN)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments     ClientJobAttachment[]
  favoriteJobs    FavoriteJob[]

  @@index([userId])
  @@index([status])
}

model FavoriteJob {
  id        Int       @id @default(autoincrement())
  userId    Int
  jobId     Int
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  job       ClientJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
}

model ClientJobAttachment {
  id         Int       @id @default(autoincrement())
  jobId      Int
  fileName   String
  fileType   String?
  fileSize   Int?
  previewUrl String?
  createdAt  DateTime  @default(now())
  job        ClientJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

model ProjectTransaction {
  id             Int      @id @default(autoincrement())
  trackingId     Int
  milestoneId    Int?
  completionId   Int?
  clientId       Int
  professionalId Int
  amount         Int
  currency       String   @default("USD")
  type           String
  status         String   @default("COMPLETED")
  description    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([trackingId])
  @@index([clientId])
  @@index([professionalId])
  @@index([status])
  @@map("ProjectTransaction")
}

model ProjectNegotiation {
  id             Int      @id @default(autoincrement())
  requestId      Int
  jobId          Int
  clientId       Int
  professionalId Int
  senderId       Int
  senderRole     String
  bidAmount      Int?
  duration       String?
  message        String
  createdAt      DateTime @default(now())

  @@index([requestId])
  @@index([clientId])
  @@index([professionalId])
  @@map("ProjectNegotiation")
}

model ProjectReview {
  id             Int      @id @default(autoincrement())
  trackingId     Int      @unique
  clientId       Int
  professionalId Int
  rating         Int
  comment        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([clientId])
  @@index([professionalId])
  @@map("ProjectReview")
}
